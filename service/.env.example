# ── LLM ──────────────────────────────────────────────────────────────────────
# Model and provider passed to LangChain's init_chat_model.
# Install the matching langchain provider package and set its API key.
#
# Anthropic (default):
#   pip install langchain-anthropic
ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
#
# OpenAI example:
#   pip install langchain-openai
# OPENAI_API_KEY=sk-...
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# ── Auth ──────────────────────────────────────────────────────────────────────
# Comma-separated API keys the extension must include as X-API-Key header.
# If unset, a random bootstrap key is generated and logged on startup.
FIELDAGENT_API_KEYS=your-secret-key-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=INFO

# ── Storage ───────────────────────────────────────────────────────────────────
# Override these when running in Docker (docker-compose sets them automatically).
# DB_PATH=/app/data/fieldagent.db
# LOGS_DIR=/app/data/logs

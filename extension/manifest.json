{
  "manifest_version": 3,
  "name": "FieldAgent",
  "version": "0.1.0",
  "description": "AI-assisted form filling for social media posting. Connects to a FieldAgent service to pre-populate fields — you always review and submit.",

  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "alarms"
  ],

  "host_permissions": [
    "https://www.facebook.com/*",
    "https://www.instagram.com/*",
    "https://www.pinterest.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.linkedin.com/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://www.instagram.com/*",
        "https://www.pinterest.com/*",
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.linkedin.com/*"
      ],
      "js": ["lib/dom-utils.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "sidepanel/index.html"
  },

  "options_page": "options/index.html",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "FieldAgent",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png"
    }
  }
}

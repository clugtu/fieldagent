{
  "manifest_version": 3,
  "name": "FieldAgent",
  "version": "0.1.0",
  "description": "An AI agent that fills in web forms. Connects to a FieldAgent service to inspect the page and pre-populate fields — you always review and submit.",

  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "sidePanel",
    "alarms",
    "downloads",
    "debugger",
    "scripting"
  ],

  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.pinterest.com/*"],
      "js": ["content/pinterest-patch.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["lib/dom-utils.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "sidepanel/index.html"
  },

  "options_page": "options/index.html",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "FieldAgent",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png"
    }
  }
}
